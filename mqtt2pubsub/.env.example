FORWARD_MODE=pubsub
MQTT_HOST=broker.example.com
MQTT_PORT=8883
# Option A: one topic filter
MQTT_TOPIC=devices/+/telemetry

# Option B: list of identifiers, each mapped to "<identifier>/#" by default
# DEVICE_IDENTIFIERS=device-a,device-b,device-c
# MQTT_TOPIC_TEMPLATE={identifier}/#
# MQTT_CONSUMER_CLIENTS=2
MQTT_QOS=1
MQTT_TLS_ENABLED=true
MQTT_TLS_INSECURE=false

PUBSUB_TOPIC=projects/your-project-id/topics/mqtt-ingest
# If PUBSUB_TOPIC is not a full projects/... path, set:
# GCP_PROJECT_ID=your-project-id

# Event type derivation:
# 1) first matching MQTT filter in EVENT_TYPE_TOPIC_MAP
# 2) first present payload JSON field in EVENT_TYPE_JSON_FIELDS
# 3) EVENT_TYPE_FALLBACK
# EVENT_TYPE_TOPIC_MAP=devices/+/telemetry=telemetry;devices/+/state=state
# EVENT_TYPE_JSON_FIELDS=event_type,type,kind
# EVENT_TYPE_FALLBACK=unknown

# Optional authentication
# MQTT_USERNAME=your-user
# MQTT_PASSWORD=your-password

# Optional runtime limits
# MAX_MESSAGES=0
# MAX_RUNTIME_SEC=0

# Optional local-only output file (used when FORWARD_MODE=stdout)
# LOCAL_OUTPUT_PATH=./local/forwarded.ndjson
